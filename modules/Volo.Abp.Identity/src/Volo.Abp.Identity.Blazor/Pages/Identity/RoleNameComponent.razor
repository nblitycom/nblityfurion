@using System;
@using Volo.Abp.Identity
@using Microsoft.Extensions.Localization
@using Volo.Abp.Identity.Localization

@inject IStringLocalizer<IdentityResource> L

@(Data.As<IdentityRoleDto>().Name)
@if (Data.As<IdentityRoleDto>().IsDefault)
{
    <MudChip T="string" Color="MudBlazor.Color.Success" Size="MudBlazor.Size.Small" Class="ml-1">@L["DisplayName:IsDefault"]</MudChip>
}
@if (Data.As<IdentityRoleDto>().IsPublic)
{
    <MudChip T="string" Color="MudBlazor.Color.Info" Size="MudBlazor.Size.Small" Class="ml-1">@L["DisplayName:IsPublic"]</MudChip>
}