@using Volo.Abp.PermissionManagement.Localization
@inherits Volo.Abp.AspNetCore.Components.AbpComponentBase

<MudDialog @bind-Visible="_visible" Options="@(new DialogOptions { MaxWidth = MaxWidth.ExtraLarge, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">@L["ResourcePermissions"] - @ResourceDisplayName</MudText>
    </TitleContent>
    <DialogContent>
        @if (HasAnyResourcePermission && HasAnyResourceProviderKeyLookupService)
        {
            <MudStack Row="true" Justify="Justify.FlexEnd" Class="mb-2">
                <MudButton Color="MudBlazor.Color.Primary" Size="MudBlazor.Size.Small" Variant="Variant.Filled" OnClick="OpenCreateModalAsync">@L["AddResourcePermission"]</MudButton>
            </MudStack>
            <MudTable Items="@ResourcePermissionList.Permissions" Dense="true" Hover="true" RowsPerPage="PageSize">
                <HeaderContent>
                    <MudTh Class="actions-column">@L["Actions"]</MudTh>
                    <MudTh>@L["ResourcePermissionTarget"]</MudTh>
                    <MudTh>@L["ResourcePermissionPermissions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudMenu Label="@L["Actions"]" Variant="Variant.Filled" Color="MudBlazor.Color.Primary" Size="MudBlazor.Size.Small">
                            <MudMenuItem OnClick="@(() => OpenEditModalAsync(context))">@L["Edit"]</MudMenuItem>
                            <MudMenuItem OnClick="@(() => DeleteResourcePermissionAsync(context))">@L["Delete"]</MudMenuItem>
                        </MudMenu>
                    </MudTd>
                    <MudTd>
                        <MudTooltip Text="@context.ProviderNameDisplayName" Placement="Placement.Right">
                            <MudChip T="string" Size="MudBlazor.Size.Small" Class="mr-1 ml-1 mb-1">@context.ProviderName</MudChip>
                        </MudTooltip>
                        @context.ProviderDisplayName
                    </MudTd>
                    <MudTd>
                        @foreach (var permission in context.Permissions)
                        {
                            <MudChip T="string" Size="MudBlazor.Size.Small" Class="mr-1 mb-1">@permission.DisplayName</MudChip>
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="@(new[] { 10, 25, 50 })" />
                </PagerContent>
                <NoRecordsContent>
                    @L["NoDataAvailableInDatatable"]
                </NoRecordsContent>
            </MudTable>
        }
        else
        {
            <MudAlert Severity="Severity.Warning">
                @if (!HasAnyResourcePermission)
                {
                    @L["NoResourcePermissionFound"]
                }
                else if (!HasAnyResourceProviderKeyLookupService)
                {
                    @L["NoResourceProviderKeyLookupServiceFound"]
                }
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseModal">@L["Close"]</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_createDialogVisible" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">@L["AddResourcePermission"]</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_createForm">
            <MudStack Class="mb-3">
                <MudRadioGroup T="string"
                               Value="@CurrentLookupService"
                               ValueChanged="@OnLookupServiceCheckedValueChanged">
                    @foreach (var keyLookupService in ResourceProviderKeyLookupServices)
                    {
                        <MudRadio T="string" Value="@keyLookupService.Name">@keyLookupService.DisplayName</MudRadio>
                    }
                </MudRadioGroup>
                <MudAutocomplete @ref="_providerKeyAutocomplete"
                                 T="SearchProviderKeyInfo"
                                 Value="@_selectedProviderKeyInfo"
                                 ValueChanged="@OnProviderKeySelectedAsync"
                                 SearchFunc="@SearchProviderKeysAsync"
                                 ToStringFunc="@(item => item?.ProviderDisplayName ?? string.Empty)"
                                 Required="true"
                                 RequiredError="@L["ThisFieldIsRequired."]"
                                 ResetValueOnEmptyText="true"
                                 Class="mt-1" />
            </MudStack>
            <MudStack Class="mb-3">
                <MudText Typo="Typo.h6">@L["ResourcePermissionPermissions"]</MudText>
                <MudSwitch T="bool" Value="CreateEntity.Permissions.All(x => x.IsGranted)" ValueChanged="GrantAllAsync" Label="@L["GrantAllResourcePermissions"]" Color="MudBlazor.Color.Primary" />
                <MudStack Class="mt-2">
                    @foreach (var permission in CreateEntity.Permissions)
                    {
                        <MudCheckBox T="bool" Value="@permission.IsGranted" ValueChanged="@((c) => OnPermissionCheckedChanged(permission, c))" Label="@permission.DisplayName" />
                    }
                </MudStack>
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseCreateModalAsync">@L["Cancel"]</MudButton>
        <MudButton Color="MudBlazor.Color.Primary" Variant="Variant.Filled" OnClick="@CreateResourcePermissionAsync">@L["Save"]</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_editDialogVisible" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">@L["UpdateResourcePermission"]</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_editForm">
            <MudStack Class="mb-3">
                <MudText Typo="Typo.h6">@L["ResourcePermissionPermissions"]</MudText>
                <MudSwitch T="bool" Value="EditEntity.Permissions.All(x => x.IsGranted)" ValueChanged="GrantAllAsync" Label="@L["GrantAllResourcePermissions"]" Color="MudBlazor.Color.Primary" />
                <MudStack Class="mt-2">
                    @foreach (var permission in EditEntity.Permissions)
                    {
                        <MudCheckBox T="bool" Value="@permission.IsGranted" ValueChanged="@((c) => OnPermissionCheckedChanged(permission, c))" Label="@permission.DisplayName" />
                    }
                </MudStack>
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseEditModalAsync">@L["Cancel"]</MudButton>
        <MudButton Color="MudBlazor.Color.Primary" Variant="Variant.Filled" OnClick="@UpdateResourcePermissionAsync">@L["Save"]</MudButton>
    </DialogActions>
</MudDialog>
