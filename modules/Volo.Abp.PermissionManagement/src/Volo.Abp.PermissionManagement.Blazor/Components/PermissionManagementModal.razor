@inherits Volo.Abp.AspNetCore.Components.AbpComponentBase
<MudDialog @bind-Visible="_visible" Options="@(new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">@L["Permissions"] - @_entityDisplayName</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid Class="align-center mb-2">
            <MudItem xs="8">
                <MudTextField T="string"
                              Value="@_permissionGroupSearchText"
                              ValueChanged="OnPermissionGroupSearchTextChangedAsync"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="4" Class="d-flex justify-end">
                <MudCheckBox T="bool?"
                             Disabled="_selectAllDisabled"
                             Value="@(GrantAny ? null : (bool?)GrantAll)"
                             ValueChanged="@OnGrantAllValueChanged"
                             Label="@L["SelectAllInAllTabs"]" />
            </MudItem>
        </MudGrid>

        <MudPaper Outlined="true" Class="rounded pa-3">
            <MudText Typo="Typo.h6" Class="mb-2">@L["PermissionGroup"]</MudText>

            @if (_groups != null && _groups.Any())
            {
                <MudStack Class="lpx-scroll-pills-container">
                    <MudTabs @bind-ActivePanelIndex="_selectedTabIndex" Position="Position.Left" Rounded="true" PanelClass="pa-3">
                        @foreach (var group in _groups)
                        {
                            <MudTabPanel Text="@GetTabText(group)">
                                <MudPaper Elevation="0" Class="w-100 ps-1 permission-scroll-container">
                                    <MudCheckBox T="bool"
                                                 Disabled="@(IsPermissionGroupDisabled(group))"
                                                 Value="@(group.Permissions.All(x => x.IsGranted))"
                                                 ValueChanged="@(b => GroupGrantAllChanged(b, group))"
                                                 Label="@L["SelectAllInThisTab"]" />

                                    <MudDivider Class="my-2" />

                                    @foreach (var permission in group.Permissions)
                                    {
                                        <MudStack Class="@($"perm-depth-{GetPermissionDepthOrDefault(permission.Name)}")">
                                            <MudCheckBox T="bool"
                                                         Disabled="@(IsDisabledPermission(permission))"
                                                         Value="@permission.IsGranted"
                                                         ValueChanged="@(async (b) => await PermissionChanged(b, group, permission))"
                                                         Label="@GetShownName(permission)" />
                                        </MudStack>
                                    }
                                </MudPaper>
                            </MudTabPanel>
                        }
                    </MudTabs>
                </MudStack>
            }
        </MudPaper>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseModal">@L["Cancel"]</MudButton>
        <MudButton Color="MudBlazor.Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync">@L["Save"]</MudButton>
    </DialogActions>
</MudDialog>
