@page
@inject IHtmlLocalizer<AccountResource> L
@using Microsoft.AspNetCore.Mvc.Localization
@using Volo.Abp.Account.Localization
@model Volo.Abp.Account.Web.Pages.Account.ForgotPasswordModel
@inject Volo.Abp.AspNetCore.Mvc.UI.Layout.IPageLayout PageLayout
@{
    Layout = "~/Pages/Account/_BlazorAccountLayout.cshtml";
    ViewData["Title"] = L["ForgotPassword"].Value;
}

<div style="display:flex;justify-content:center;align-items:center;min-height:100vh;background:#f5f5f5;padding:16px;">
    <div class="mud-paper mud-paper-elevation-4" style="width:100%;max-width:440px;padding:32px 40px;border-radius:8px;background:#fff;">
        <div class="mud-typography mud-typography-h5" style="margin-bottom:8px;font-weight:600;">
            @L["ForgotPassword"]
        </div>
        <div class="mud-typography mud-typography-body1" style="margin-bottom:24px;color:#616161;">
            @L["SendPasswordResetLink_Information"]
        </div>
        <form method="post">
            <div style="margin-bottom:16px;">
                <label for="Email" class="mud-typography mud-typography-body2" style="display:block;margin-bottom:4px;font-weight:500;">
                    @L["DisplayName:Email"]
                </label>
                <input asp-for="Email" type="email" required
                       style="width:100%;padding:10px 12px;border:1px solid #bdbdbd;border-radius:4px;font-size:1rem;font-family:Roboto,sans-serif;outline:none;box-sizing:border-box;"
                       onfocus="this.style.borderColor='#5b6abf'" onblur="this.style.borderColor='#bdbdbd'" />
                <span asp-validation-for="Email" style="color:#d32f2f;font-size:0.75rem;"></span>
            </div>
            <button type="submit"
                    class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-button-default mud-ripple"
                    style="width:100%;padding:10px 16px;border-radius:4px;border:none;cursor:pointer;font-weight:500;font-size:0.875rem;text-transform:uppercase;letter-spacing:.04em;margin-bottom:16px;">
                <span class="mud-button-label">@L["Submit"]</span>
            </button>
        </form>
        <div style="text-align:center;">
            <a href="@Url.Page("./Login", new { returnUrl = Model.ReturnUrl, returnUrlHash = Model.ReturnUrlHash })"
               style="color:#5b6abf;text-decoration:none;font-size:0.875rem;">
                &larr; @L["Login"]
            </a>
        </div>
    </div>
</div>
