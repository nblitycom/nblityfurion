@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.AspNetCore.Antiforgery
@using Volo.Abp.Account.Localization
@using Volo.Abp.Account.Settings
@using Volo.Abp.Account.Web.Pages.Account
@using Volo.Abp.Account.Blazor.Pages.Account
@using Volo.Abp.Settings
@model Volo.Abp.Account.Web.Pages.Account.LoginModel
@inject IHtmlLocalizer<AccountResource> L
@inject IAntiforgery Antiforgery
@inject Volo.Abp.Settings.ISettingProvider SettingProvider

@{
    Layout = "~/Pages/Account/_BlazorAccountLayout.cshtml";
    var antiForgeryToken = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken ?? string.Empty;
}

<component type="typeof(LoginComponent)" render-mode="Static"
           param-ReturnUrl="@Model.ReturnUrl"
           param-ReturnUrlHash="@Model.ReturnUrlHash"
           param-EnableLocalLogin="@Model.EnableLocalLogin"
           param-ShowCancelButton="@Model.ShowCancelButton"
           param-ShowRequireMigrateSeedMessage="@Model.ShowRequireMigrateSeedMessage"
           param-HasExternalProviders="@Model.VisibleExternalProviders.Any()"
           param-AntiForgeryToken="@antiForgeryToken" />

@if (Model.VisibleExternalProviders.Any())
{
    <div style="display:flex;flex-direction:column;align-items:center;padding:0 16px 32px;">
        <div class="mud-paper mud-paper-elevation-4"
             style="width:100%;max-width:440px;padding:24px 40px 32px;border-radius:8px;background:#fff;margin-top:-8px;">
            <div class="mud-typography mud-typography-subtitle1" style="margin-bottom:12px;font-weight:500;">
                @L["OrLoginWith"]
            </div>
            <form asp-page="./Login" asp-page-handler="ExternalLogin"
                  asp-route-returnUrl="@Model.ReturnUrl"
                  asp-route-returnUrlHash="@Model.ReturnUrlHash" method="post">
                @foreach (var provider in Model.VisibleExternalProviders)
                {
                    <button type="submit"
                            class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-button-default mud-ripple"
                            name="provider" value="@provider.AuthenticationScheme"
                            style="margin:4px;padding:6px 16px;height:36px;border-radius:4px;border:none;cursor:pointer;font-weight:500;font-size:0.875rem;text-transform:uppercase;letter-spacing:.04em;"
                            title="@L["LogInUsingYourProviderAccount", provider.DisplayName]">
                        <span class="mud-button-label">@provider.DisplayName</span>
                    </button>
                }
            </form>
        </div>
    </div>
}
