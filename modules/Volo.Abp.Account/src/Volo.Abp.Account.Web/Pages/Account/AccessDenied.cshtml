@page
@model Volo.Abp.Account.Web.Pages.Account.AccessDeniedModel
@using Microsoft.AspNetCore.Mvc.Localization
@using Volo.Abp.Account.Localization
@inject IHtmlLocalizer<AccountResource> L
@{
    Layout = "~/Pages/Account/_BlazorAccountLayout.cshtml";
    ViewData["Title"] = L["AccessDenied"].Value;
}

<div style="display:flex;justify-content:center;align-items:center;min-height:100vh;background:#f5f5f5;padding:16px;">
    <div class="mud-paper mud-paper-elevation-4" style="width:100%;max-width:440px;padding:32px 40px;border-radius:8px;background:#fff;text-align:center;">
        <div class="mud-typography mud-typography-h5" style="margin-bottom:16px;font-weight:600;color:#d32f2f;">
            @L["AccessDenied"]
        </div>
        <div class="mud-typography mud-typography-body1" style="margin-bottom:24px;color:#616161;">
            @L["AccessDeniedMessage"]
        </div>
        <a href="@Url.Page("./Login", new { returnUrl = Model.ReturnUrl, returnUrlHash = Model.ReturnUrlHash })"
           class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-button-default mud-ripple"
           style="display:inline-flex;align-items:center;padding:6px 16px;border-radius:4px;text-decoration:none;font-weight:500;font-size:0.875rem;text-transform:uppercase;letter-spacing:.04em;">
            <span class="mud-button-label">&larr; @L["BackToLogin"]</span>
        </a>
    </div>
</div>
