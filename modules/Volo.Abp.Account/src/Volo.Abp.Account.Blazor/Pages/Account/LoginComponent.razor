@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Localization
@using Volo.Abp.Account.Localization
@inject IStringLocalizer<AccountResource> L

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="login-page-container d-flex align-center justify-center">
    <MudPaper Elevation="4" Class="login-card pa-10 rounded">

        <MudText Typo="Typo.h5" GutterBottom="true">@L["Login"]</MudText>

        @if (ShowRequireMigrateSeedMessage)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">
                <MudText Typo="Typo.subtitle2">@L["RequireMigrateSeedTitle"]</MudText>
                <MudText Typo="Typo.body2">@L["RequireMigrateSeedMessage"]</MudText>
            </MudAlert>
        }

        @if (EnableLocalLogin)
        {
            <form method="post">
                <input type="hidden" name="__RequestVerificationToken" value="@AntiForgeryToken" />
                <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
                <input type="hidden" name="ReturnUrlHash" value="@ReturnUrlHash" />

                <MudTextField @bind-Value="_userNameOrEmail"
                              Label="@L["UserNameOrEmailAddress"]"
                              InputType="InputType.Text"
                              AutoFocus="true"
                              Variant="Variant.Outlined"
                              UserAttributes="_userNameAttributes"
                              Class="mb-4" />

                <MudTextField @bind-Value="_password"
                              Label="@L["Password"]"
                              InputType="InputType.Password"
                              MaxLength="128"
                              Variant="Variant.Outlined"
                              UserAttributes="_passwordAttributes"
                              Class="mb-4" />

                <MudCheckBox @bind-Value="_rememberMe"
                             Label="@L["RememberMe"]"
                             UserAttributes="_rememberMeAttributes"
                             Class="mb-4" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="MudBlazor.Color.Primary"
                           FullWidth="true"
                           UserAttributes="_loginButtonAttributes"
                           Class="mb-2">
                    @L["Login"]
                </MudButton>

                @if (ShowCancelButton)
                {
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Outlined"
                               Color="MudBlazor.Color.Secondary"
                               FullWidth="true"
                               UserAttributes="_cancelButtonAttributes"
                               Class="mt-2">
                        @L["Cancel"]
                    </MudButton>
                }
            </form>
        }

        @if (!EnableLocalLogin && !HasExternalProviders)
        {
            <MudAlert Severity="Severity.Warning" Class="mt-4">
                <strong>@L["InvalidLoginRequest"]</strong>
                @L["ThereAreNoLoginSchemesConfiguredForThisClient"]
            </MudAlert>
        }
    </MudPaper>
</MudContainer>

@code {
    private string _userNameOrEmail = string.Empty;
    private string _password = string.Empty;
    private bool _rememberMe = false;

    private static readonly Dictionary<string, object> _userNameAttributes = new()
    {
        { "name", "LoginInput.UserNameOrEmailAddress" },
        { "id", "LoginInput_UserNameOrEmailAddress" },
        { "autocomplete", "username" }
    };

    private static readonly Dictionary<string, object> _passwordAttributes = new()
    {
        { "name", "LoginInput.Password" },
        { "id", "LoginInput_Password" },
        { "autocomplete", "current-password" }
    };

    private static readonly Dictionary<string, object> _rememberMeAttributes = new()
    {
        { "name", "LoginInput.RememberMe" }
    };

    private static readonly Dictionary<string, object> _loginButtonAttributes = new()
    {
        { "name", "Action" },
        { "value", "Login" }
    };

    private static readonly Dictionary<string, object> _cancelButtonAttributes = new()
    {
        { "name", "Action" },
        { "value", "Cancel" },
        { "formnovalidate", "formnovalidate" }
    };

    [Parameter] public string ReturnUrl { get; set; } = string.Empty;
    [Parameter] public string ReturnUrlHash { get; set; } = string.Empty;
    [Parameter] public bool EnableLocalLogin { get; set; } = true;
    [Parameter] public bool ShowCancelButton { get; set; }
    [Parameter] public bool ShowRequireMigrateSeedMessage { get; set; }
    [Parameter] public bool HasExternalProviders { get; set; }
    [Parameter] public string AntiForgeryToken { get; set; } = string.Empty;
}
