@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Localization
@using Volo.Abp.Account.Localization
@inject IStringLocalizer<AccountResource> L

<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;background-color:#f5f5f5;padding:16px;">
    <div class="mud-paper mud-paper-elevation-4"
         style="width:100%;max-width:440px;padding:40px;border-radius:8px;background:#fff;">

        <div class="mud-typography mud-typography-h5" style="margin-bottom:24px;font-weight:500;">@L["Login"]</div>

        @if (ShowRequireMigrateSeedMessage)
        {
            <div style="background-color:#f44336;color:#fff;padding:12px 16px;border-radius:4px;margin-bottom:16px;">
                <div style="font-weight:600;margin-bottom:4px;">@L["RequireMigrateSeedTitle"]</div>
                <div>@L["RequireMigrateSeedMessage"]</div>
            </div>
        }

        @if (EnableLocalLogin)
        {
            <form method="post">
                <input type="hidden" name="__RequestVerificationToken" value="@AntiForgeryToken" />
                <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
                <input type="hidden" name="ReturnUrlHash" value="@ReturnUrlHash" />

                <div class="mud-input-control" style="margin-bottom:24px;">
                    <div class="mud-input-control-input-container">
                        <div class="mud-input mud-input-outlined mud-shrink">
                            <input class="mud-input-slot mud-input-root mud-input-root-outlined"
                                   type="text"
                                   id="LoginInput_UserNameOrEmailAddress"
                                   name="LoginInput.UserNameOrEmailAddress"
                                   autocomplete="username"
                                   placeholder=" " />
                            <div class="mud-input-outlined-border"></div>
                        </div>
                        <label class="mud-input-label mud-input-label-animated mud-input-label-outlined mud-input-label-inputcontrol"
                               for="LoginInput_UserNameOrEmailAddress">
                            @L["UserNameOrEmailAddress"]
                        </label>
                    </div>
                </div>

                <div class="mud-input-control" style="margin-bottom:24px;">
                    <div class="mud-input-control-input-container">
                        <div class="mud-input mud-input-outlined mud-shrink">
                            <input class="mud-input-slot mud-input-root mud-input-root-outlined"
                                   type="password"
                                   id="LoginInput_Password"
                                   name="LoginInput.Password"
                                   autocomplete="current-password"
                                   placeholder=" "
                                   maxlength="128" />
                            <div class="mud-input-outlined-border"></div>
                        </div>
                        <label class="mud-input-label mud-input-label-animated mud-input-label-outlined mud-input-label-inputcontrol"
                               for="LoginInput_Password">
                            @L["Password"]
                        </label>
                    </div>
                </div>

                <div style="margin-bottom:24px;display:flex;align-items:center;">
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;user-select:none;">
                        <input type="checkbox" name="LoginInput.RememberMe" value="true"
                               style="width:18px;height:18px;cursor:pointer;accent-color:#5b6abf;" />
                        <span class="mud-typography mud-typography-body2">@L["RememberMe"]</span>
                    </label>
                </div>

                <button type="submit" name="Action" value="Login"
                        class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-button-default mud-ripple"
                        style="width:100%;height:42px;text-transform:uppercase;font-weight:500;font-size:0.875rem;letter-spacing:.04em;margin-bottom:8px;">
                    <span class="mud-button-label">@L["Login"]</span>
                </button>

                @if (ShowCancelButton)
                {
                    <button type="submit" name="Action" value="Cancel" formnovalidate
                            class="mud-button-root mud-button mud-button-outlined mud-button-outlined-secondary mud-button-default mud-ripple"
                            style="width:100%;height:42px;text-transform:uppercase;font-weight:500;font-size:0.875rem;letter-spacing:.04em;margin-top:8px;">
                        <span class="mud-button-label">@L["Cancel"]</span>
                    </button>
                }
            </form>
        }

        @if (!EnableLocalLogin && !HasExternalProviders)
        {
            <div style="background-color:#ff9800;color:#fff;padding:12px 16px;border-radius:4px;margin-top:16px;">
                <strong>@L["InvalidLoginRequest"]</strong>
                @L["ThereAreNoLoginSchemesConfiguredForThisClient"]
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string ReturnUrl { get; set; } = string.Empty;
    [Parameter] public string ReturnUrlHash { get; set; } = string.Empty;
    [Parameter] public bool EnableLocalLogin { get; set; } = true;
    [Parameter] public bool ShowCancelButton { get; set; }
    [Parameter] public bool ShowRequireMigrateSeedMessage { get; set; }
    [Parameter] public bool HasExternalProviders { get; set; }
    [Parameter] public string AntiForgeryToken { get; set; } = string.Empty;
}
