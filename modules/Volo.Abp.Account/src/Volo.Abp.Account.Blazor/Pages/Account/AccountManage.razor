@page "/account/manage-profile"
@using Microsoft.AspNetCore.Components.Forms
@using Volo.Abp.Account.Localization
@using Volo.Abp.AspNetCore.Components.Web
@using Volo.Abp.ObjectExtending
@using Volo.Abp.Data

@inject AbpBlazorMessageLocalizerHelper<AccountResource> LH
@inherits AbpAccountComponentBase

<MudTabs Position="Position.Left" Rounded="true" PanelClass="pa-3">
    <MudTabPanel Text="@L["ProfileTab:Password"]" ID="@("Password")">
        @if (ChangePasswordModel != null)
        {
            <EditForm id="ChangePasswordForm" Model="@ChangePasswordModel" OnValidSubmit="ChangePasswordAsync">
                @if (!ChangePasswordModel.HideOldPasswordInput)
                {
                    <MudTextField @bind-Value="@ChangePasswordModel.CurrentPassword"
                                  Label="@L["DisplayName:CurrentPassword"]"
                                  InputType="InputType.Password" Class="mt-3" />
                }
                <MudTextField @bind-Value="@ChangePasswordModel.NewPassword"
                              Label="@L["DisplayName:NewPassword"]"
                              InputType="InputType.Password" Class="mt-3" />
                <MudTextField @bind-Value="@ChangePasswordModel.NewPasswordConfirm"
                              Label="@L["DisplayName:NewPasswordConfirm"]"
                              InputType="InputType.Password" Class="mt-3" />
                <MudStack Class="mt-3">
                    <MudButton Color="MudBlazor.Color.Primary" Variant="Variant.Filled"
                               OnClick="ChangePasswordAsync">@L["Save"]</MudButton>
                </MudStack>
            </EditForm>
        }
    </MudTabPanel>
    <MudTabPanel Text="@L["ProfileTab:PersonalInfo"]" ID="@("PersonalInfo")">
        @if (PersonalInfoModel != null)
        {
            <EditForm id="UpdatePersonalInfoForm" Model="@PersonalInfoModel" OnValidSubmit="UpdatePersonalInfoAsync">
                <MudTextField @bind-Value="@PersonalInfoModel.UserName"
                              Label="@L["DisplayName:UserName"]" Class="mt-3" />
                <MudGrid>
                    <MudItem xs="6">
                        <MudTextField @bind-Value="@PersonalInfoModel.Name"
                                      Label="@L["DisplayName:Name"]" Class="mt-3" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudTextField @bind-Value="@PersonalInfoModel.Surname"
                                      Label="@L["DisplayName:Surname"]" Class="mt-3" />
                    </MudItem>
                </MudGrid>
                <MudTextField @bind-Value="@PersonalInfoModel.Email"
                              Label="@L["DisplayName:Email"]"
                              InputType="InputType.Email" Class="mt-3" />
                <MudTextField @bind-Value="@PersonalInfoModel.PhoneNumber"
                              Label="@L["DisplayName:PhoneNumber"]" Class="mt-3" />

                @foreach (var propertyInfo in ObjectExtensionManager.Instance.GetProperties<PersonalInfoModel>())
                {
                    var isAllowed = propertyInfo.Configuration.GetOrDefault(IdentityModuleExtensionConsts.ConfigurationNames.AllowUserToEdit);

                    if (isAllowed == null || !isAllowed.Equals(true))
                    {
                        continue;
                    }

                    if (!propertyInfo.Name.EndsWith("_Text"))
                    {
                        if (propertyInfo.Type is { IsEnum: true })
                        {
                            <SelectExtensionProperty PropertyInfo="@propertyInfo" Entity="@PersonalInfoModel" TEntity="PersonalInfoModel" TResourceType="AccountResource" LH="@LH" />
                        }
                        else if (!propertyInfo.Lookup.Url.IsNullOrEmpty())
                        {
                            <LookupExtensionProperty PropertyInfo="@propertyInfo" Entity="@PersonalInfoModel" TEntity="PersonalInfoModel" TResourceType="AccountResource" LH="@LH" />
                        }
                        else
                        {
                            <MudTextField T="string"
                                          Label="@propertyInfo.Name"
                                          Value="@(PersonalInfoModel.ExtraProperties.ContainsKey(propertyInfo.Name) ? PersonalInfoModel.ExtraProperties[propertyInfo.Name]?.ToString() : null)"
                                          ValueChanged="@((string v) => PersonalInfoModel.ExtraProperties[propertyInfo.Name] = v)"
                                          Class="mt-3" />
                        }
                    }
                }
                <MudStack Class="mt-3">
                    <MudButton Color="MudBlazor.Color.Primary" Variant="Variant.Filled"
                               OnClick="UpdatePersonalInfoAsync">@L["Save"]</MudButton>
                </MudStack>
            </EditForm>
        }
    </MudTabPanel>
</MudTabs>
