@using Volo.Abp.SettingManagement.Localization
@inherits Volo.Abp.AspNetCore.Components.AbpComponentBase
@inject AbpBlazorMessageLocalizerHelper<AbpSettingManagementResource> LH

@if (EmailSettings != null)
{
    <MudForm @ref="_emailForm">
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="@EmailSettings.DefaultFromDisplayName"
                              Label="@($"{L["DefaultFromDisplayName"]} *")"
                              Class="mt-3" />
                <MudTextField @bind-Value="@EmailSettings.DefaultFromAddress"
                              Label="@($"{L["DefaultFromAddress"]} *")"
                              InputType="InputType.Email" Class="mt-3" />
                <MudTextField @bind-Value="@EmailSettings.SmtpHost"
                              Label="@L["SmtpHost"]" Class="mt-3" />
                <MudNumericField T="int" @bind-Value="@EmailSettings.SmtpPort"
                                 Label="@L["SmtpPort"]" Class="mt-3" />
                <MudCheckBox T="bool" @bind-Value="@EmailSettings.SmtpEnableSsl"
                             Label="@L["SmtpEnableSsl"]" Class="mt-3" />
                <MudCheckBox T="bool" @bind-Value="@EmailSettings.SmtpUseDefaultCredentials"
                             Label="@L["SmtpUseDefaultCredentials"]" Class="mt-3" />
                @if (!EmailSettings.SmtpUseDefaultCredentials)
                {
                    <MudTextField @bind-Value="@EmailSettings.SmtpDomain"
                                  Label="@L["SmtpDomain"]" Class="mt-3" />
                    <MudTextField @bind-Value="@EmailSettings.SmtpUserName"
                                  Label="@L["SmtpUserName"]" Class="mt-3" />
                    <MudTextField @bind-Value="@EmailSettings.SmtpPassword"
                                  Label="@L["SmtpPassword"]"
                                  InputType="@(_showSmtpPassword ? InputType.Text : InputType.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showSmtpPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                  OnAdornmentClick="@(() => _showSmtpPassword = !_showSmtpPassword)"
                                  Placeholder="@L["SmtpPasswordPlaceholder"].Value"
                                  Class="mt-3" />
                }
            </MudItem>
        </MudGrid>
        <MudDivider Class="mt-3 mb-3" />
        <MudStack Row="true" Spacing="2">
            @if (HasSendTestEmailPermission)
            {
                <MudButton Color="MudBlazor.Color.Secondary" Variant="Variant.Outlined"
                           OnClick="OpenSendTestEmailModalAsync">@L["SendTestEmail"]</MudButton>
            }
            <MudButton Color="MudBlazor.Color.Primary" Variant="Variant.Filled"
                       OnClick="@UpdateSettingsAsync">@L["Save"]</MudButton>
        </MudStack>
    </MudForm>

    @if (HasSendTestEmailPermission)
    {
        <MudDialog @bind-Visible="_sendTestEmailVisible" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
            <TitleContent>
                <MudText Typo="Typo.h6">@L["SendTestEmail"]</MudText>
            </TitleContent>
            <DialogContent>
                <MudForm @ref="_testEmailForm">
                    <MudTextField @bind-Value="@SendTestEmailInput.SenderEmailAddress"
                                  Label="@($"{L["SenderEmailAddress"]} *")"
                                  InputType="InputType.Email" AutoFocus="true" Class="mt-3" />
                    <MudTextField @bind-Value="@SendTestEmailInput.TargetEmailAddress"
                                  Label="@($"{L["TargetEmailAddress"]} *")"
                                  InputType="InputType.Email" Class="mt-3" />
                    <MudTextField @bind-Value="@SendTestEmailInput.Subject"
                                  Label="@($"{L["Subject"]} *")" Class="mt-3" />
                    <MudTextField @bind-Value="@SendTestEmailInput.Body"
                                  Label="@L["Body"]" Class="mt-3" Lines="3" />
                </MudForm>
            </DialogContent>
            <DialogActions>
                <MudButton OnClick="CloseSendTestEmailModalAsync">@L["Cancel"]</MudButton>
                <MudButton Color="MudBlazor.Color.Primary" Variant="Variant.Filled"
                           OnClick="SendTestEmailAsync">@L["Send"]</MudButton>
            </DialogActions>
        </MudDialog>
    }
}
