@inherits Volo.Abp.AspNetCore.Components.AbpComponentBase

@if (Settings != null && Settings.HasManageHostFeaturesPermission)
{
    <MudText Class="mb-3">@L["ManageHostFeaturesText"]</MudText>
    <MudButton Size="MudBlazor.Size.Small" Color="MudBlazor.Color.Primary" Variant="Variant.Filled"
               OnClick="@OnManageHostFeaturesClicked">
        <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-1" />
        @L["ManageHostFeatures"]
    </MudButton>

    <FeatureManagementModal @ref="FeatureManagementModal"/>
}
