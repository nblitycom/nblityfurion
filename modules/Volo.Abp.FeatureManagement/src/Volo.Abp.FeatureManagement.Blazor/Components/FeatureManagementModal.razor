@using Volo.Abp.Validation.StringValues
@using Microsoft.Extensions.Localization
@inherits AbpFeatureManagementComponentBase

<MudDialog @bind-Visible="_featureModalVisible" Options="@(new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">@L["Features"]@ProviderKeyDisplayName</MudText>
    </TitleContent>
    <DialogContent>
        @if (Groups == null || !Groups.Any())
        {
            <MudText Class="ma-3">@L["NoFeatureFoundMessage"]</MudText>
        }
        else
        {
            <MudTabs Position="Position.Left" Rounded="true" PanelClass="pa-3">
                @foreach (var group in Groups)
                {
                    var capturedGroup = group;
                    <MudTabPanel Text="@capturedGroup.DisplayName" ID="@GetNormalizedGroupName(capturedGroup.Name)">
                        <MudText Typo="Typo.h6">@capturedGroup.DisplayName</MudText>
                        <MudDivider Class="mt-2 mb-3" />
                        @foreach (var feature in capturedGroup.Features)
                        {
                            var capturedFeature = feature;
                            <MudStack Class="@($"mt-2 feature-depth-{capturedFeature.Depth}")">
                                @{
                                    var disabled = IsDisabled(capturedFeature);
                                    if (capturedFeature.ValueType is FreeTextStringValueType)
                                    {
                                        <MudTextField Value="@capturedFeature.Value"
                                                      ValueChanged="@(async (string v) => await OnFeatureValueChangedAsync(v, capturedFeature))"
                                                      Label="@GetShownName(capturedFeature)"
                                                      Disabled="@disabled"
                                                      Class="mt-2" />
                                        @if (capturedFeature.Description != null)
                                        {
                                            <MudText Typo="Typo.caption" Class="mt-1">@capturedFeature.Description</MudText>
                                        }
                                    }
                                    else if (capturedFeature.ValueType is SelectionStringValueType selectionType)
                                    {
                                        var items = selectionType.ItemSource.Items;
                                        <MudSelect T="string" Value="@SelectionStringValues[capturedFeature.Name]"
                                                   ValueChanged="@(s => SelectionStringValues[capturedFeature.Name] = s)"
                                                   Label="@GetShownName(capturedFeature)"
                                                   Disabled="@disabled"
                                                   Class="mt-2">
                                            @foreach (var item in items)
                                            {
                                                <MudSelectItem Value="@item.Value">
                                                    @CreateStringLocalizer(item.DisplayText.ResourceName).GetString(item.DisplayText.Name)
                                                </MudSelectItem>
                                            }
                                        </MudSelect>
                                        @if (capturedFeature.Description != null)
                                        {
                                            <MudText Typo="Typo.caption" Class="mt-1">@capturedFeature.Description</MudText>
                                        }
                                    }
                                    else if (capturedFeature.ValueType is ToggleStringValueType)
                                    {
                                        <MudCheckBox T="bool" Value="@ToggleValues[capturedFeature.Name]"
                                                     ValueChanged="@(async (bool v) => await OnSelectedValueChangedAsync(v, capturedFeature))"
                                                     Label="@GetShownName(capturedFeature)"
                                                     Disabled="@disabled" />
                                        @if (capturedFeature.Description != null)
                                        {
                                            <MudText Typo="Typo.caption" Class="mt-1">@capturedFeature.Description</MudText>
                                        }
                                    }
                                }
                            </MudStack>
                        }
                    </MudTabPanel>
                }
            </MudTabs>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseModal">@L["Cancel"]</MudButton>
        <MudButton Color="MudBlazor.Color.Secondary" Variant="Variant.Outlined"
                   OnClick="@(async () => await DeleteAsync(ProviderName, ProviderKey))">@L["ResetToDefault"]</MudButton>
        <MudButton Color="MudBlazor.Color.Primary" Variant="Variant.Filled"
                   OnClick="SaveAsync">@L["Save"]</MudButton>
    </DialogActions>
</MudDialog>
